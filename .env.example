# AIluadao Environment Configuration
# Copy this file to .env and fill in the actual values

# Flask Configuration
# REQUIRED: Secret key for session management (generate a strong random string)
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Gemini AI API Configuration
# REQUIRED: Get your API key from https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# Flask Environment
# Options: development, production
FLASK_ENV=development

# Flask Debug Mode
# DANGER: Only set to True in development. Always False in production!
FLASK_DEBUG=False
